# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db
hero-screenshot*.png
_imglist.txt

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (секреты — НИКОГДА не коммитим)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editors / IDE
.idea/
.vscode/*
!.vscode/extensions.json

# исходные медиа-материалы (тяжёлые оригиналы)
/media-raw

# тяжёлые / исходные форматы — не деплоить
*.MOV
*.mov
*.heic
*.HEIC

# JPEG-оригиналы после конвертации в WebP (не деплоить лишнее)
public/images/**/*.jpg
public/images/**/*.jpeg
public/images/**/*.JPG
# Исключения: файлы, которые реально отдаёт сайт
!public/images/hero/new-hero.jpg
!public/images/services/ground-court.jpg
!public/images/services/yoga-studio.jpg
!public/images/services/ofp-training.jpg
!public/images/services/dance-studio.jpg
!public/images/services/gym-hall.jpg
!public/images/services/karate.jpg
!public/images/videos/**
