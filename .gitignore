# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (секреты — НИКОГДА не коммитим)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editors / IDE
.idea/
.vscode/*
!.vscode/extensions.json

# исходные медиа-материалы (тяжёлые оригиналы и скрипты обработки —
# не нужны в репозитории; на сайте используются .webp из public/images)
/media-raw

# JPEG-оригиналы после конвертации в WebP (не деплоить ~10 MB лишних)
public/images/**/*.jpg
public/images/**/*.jpeg
public/images/**/*.JPG
