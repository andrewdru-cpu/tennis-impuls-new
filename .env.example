# Переменные окружения проекта ЦТТ «Импульс»
#
# Сейчас проект работает БЕЗ переменных окружения — этот файл задел на будущее.
# Когда появятся интеграции, скопируйте файл в .env.local и заполните значения.
# В Vercel переменные добавляются в Project → Settings → Environment Variables.

# --- YCLIENTS (онлайн-запись), когда будет подключаться ---
# YCLIENTS_API_TOKEN=
# YCLIENTS_COMPANY_ID=

# --- Отправка заявок формы записи (почта / CRM / телеграм-бот) ---
# BOOKING_WEBHOOK_URL=
